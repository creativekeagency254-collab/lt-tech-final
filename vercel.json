{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.lifetimetechnology.store"
        }
      ],
      "destination": "https://lifetimetechnology.store/$1",
      "permanent": true
    }
  ]
}
